<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Icm.Wpf.Controls"
                    xmlns:local="clr-namespace:Icm.Wpf.Controls">
    <controls:AutoFilterDataGridFilterButtonVisibilityConverter x:Key="AutoFilterDataGridFilterButtonVisibilityConverter" />

    <DataTemplate x:Key="AutoFilterDataGridColumnHeaderContentTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ContentPresenter Content="{Binding}"
                              VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Margin="6,0,0,0"
                    Width="18"
                    Height="18"
                    Padding="0"
                    Focusable="False"
                    ToolTip="{x:Static local:AutoFilterUiResources.SearchFilterSelectedHeader}"
                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:AutoFilterDataGrid}},
                                      Path=ShowColumnFilterMenuCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridColumnHeader}}}">
                <Button.Visibility>
                    <MultiBinding Converter="{StaticResource AutoFilterDataGridFilterButtonVisibilityConverter}">
                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type controls:AutoFilterDataGrid}}"
                                 Path="CanUserFilterData" />
                        <Binding RelativeSource="{RelativeSource AncestorType={x:Type DataGridColumnHeader}}"
                                 Path="Column" />
                    </MultiBinding>
                </Button.Visibility>
                <Button.Style>
                    <Style TargetType="{x:Type Button}">
                        <Setter Property="Foreground"
                                Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="BorderBrush"
                                Value="Transparent" />
                        <Setter Property="Opacity"
                                Value="0.72" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="1" />
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridColumnHeader}},
                                                           Path=Column.(controls:AutoFilterDataGrid.HasActiveFilter)}"
                                         Value="True">
                                <Setter Property="Opacity"
                                        Value="1" />
                                <Setter Property="Foreground"
                                        Value="#FFFFC107" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock Text="▼"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>
    </DataTemplate>

    <Style x:Key="AutoFilterDataGridColumnHeaderStyle"
           TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
        <Setter Property="ContentTemplate"
                Value="{StaticResource AutoFilterDataGridColumnHeaderContentTemplate}" />
    </Style>

    <Style TargetType="{x:Type controls:AutoFilterDataGrid}"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="ColumnHeaderStyle"
                Value="{StaticResource AutoFilterDataGridColumnHeaderStyle}" />
    </Style>
</ResourceDictionary>
